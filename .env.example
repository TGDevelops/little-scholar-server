PORT=3000
DATABASE_URL="postgresql://little_scholar:little_scholar_password@localhost:5432/little_scholar?schema=public"
DIRECT_URL="postgresql://little_scholar:little_scholar_password@localhost:5432/little_scholar?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
AI_PROVIDER=gemini
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GEMINI_MODEL="gemini-2.5-flash-lite"
# Railway/deployed environments can use one of these instead of local gcloud ADC.
# Prefer base64 to avoid multiline JSON escaping issues in env var dashboards.
GOOGLE_APPLICATION_CREDENTIALS_BASE64=""
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
CORS_ORIGIN="http://localhost:3000"
